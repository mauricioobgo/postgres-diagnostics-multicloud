# PostgreSQL Memory Diagnostics environment example
# Copy to .env and adjust values for your environment.

PGMD_DSN=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
PGMD_CLOUD=aws
PGMD_INSTANCE_MEMORY_GIB=16
PGMD_APP_NAME=pg-memory-diagnostics
PGMD_OUTPUT=reports/postgres-memory-report.html
PGMD_SNAPSHOT_OUT=reports/postgres-memory-snapshot.json

