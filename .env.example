# PostgreSQL Memory & Storage Diagnostics environment example
# Copy to .env and adjust values for your environment.

# --- Direct DSN connection ---------------------------------------------------
PGMD_DSN=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
PGMD_CLOUD=aws
PGMD_INSTANCE_MEMORY_GIB=16
PGMD_APP_NAME=pg-memory-diagnostics
PGMD_OUTPUT=reports/postgres-diagnostics-report.html
PGMD_SNAPSHOT_OUT=reports/postgres-diagnostics-snapshot.json

# --- Cloud SQL Auth Proxy connection (alternative to PGMD_DSN) ---------------
# Uncomment these and leave PGMD_DSN unset to connect through a locally running
# Cloud SQL Auth Proxy. The proxy encrypts the connection itself.
# PGMD_CLOUDSQL_PROXY=true
# PGMD_CLOUDSQL_PROXY_MODE=tcp           # tcp | unix
# PGMD_CLOUDSQL_INSTANCE=PROJECT:REGION:INSTANCE   # required for unix mode
# PGMD_CLOUDSQL_PROXY_HOST=127.0.0.1
# PGMD_CLOUDSQL_PROXY_PORT=5432
# PGMD_CLOUDSQL_SOCKET_DIR=/cloudsql
# PGMD_DB_USER=reporter
# PGMD_DB_PASSWORD=CHANGE_ME
# PGMD_DB_NAME=appdb
